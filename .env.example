# LINE Bot Credentials
# Get these from LINE Developers Console: https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# OpenAI API Key (for Whisper speech-to-text)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
VOICE_TRANSCRIBE_MODEL=whisper-1
VOICE_NORMALIZE_MODEL=gpt-4.1-mini

# Gemini API Key (for text/image processing)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server port (optional, default: 8000)
PORT=8000

# Public HTTPS base URL (optional)
# Used when LINE Bot returns usage-card images. Usually inferred from deployment headers.
# Set this if your platform does not send X-Forwarded-Proto / X-Forwarded-Host correctly.
LINE_BOT_PUBLIC_BASE_URL=https://your-line-bot.example.com

# Notion Integration (optional)
# Get API key from: https://www.notion.so/my-integrations
# 1. Create a new integration and copy the "Internal Integration Token"
# 2. Create a database in Notion and share it with your integration
# 3. Copy the database ID from the URL (notion.so/[database_id]?v=...)
NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID=xxx
NOTION_SOCIAL_DATABASE_ID=xxx  # Database for social media analysis

# Apify API Key (for social media scraping)
# Get from: https://console.apify.com/account/integrations
APIFY_API_KEY=apify_api_xxx

# Accounting Knowledge Base → Notion (optional)
# 把 C:/vibe coding/Accounting/vault 的會計法規 / SOP / 行事曆匯入 Notion
# 設定步驟見 accounting/notion_setup.md
NOTION_ACCOUNTING_PARENT_PAGE_ID=
ACCOUNTING_VAULT_PATH=C:/vibe coding/Accounting/vault

# Google Drive (Obsidian Vault) - for Sources/Wiki/Meetings/log.md.
# Point GDRIVE_VAULT_FOLDER_ID at the canonical outer ObsidianVault folder.
# Service Account credentials (本地用 .json 檔，Zeabur 用 GDRIVE_CREDENTIALS_JSON 整段 JSON 字串)
GDRIVE_CREDENTIALS_FILE=gdrive_credentials.json
GDRIVE_CREDENTIALS_JSON=
GDRIVE_VAULT_FOLDER_ID=

# Google Calendar (可填多個 ID，用逗號分隔)
GOOGLE_CALENDAR_ID=primary

# Cron Job 鑑權（Zeabur Cron Job 呼叫 /cron/weekly 時帶上）
# 隨意產生一段隨機字串即可，例如 openssl rand -hex 32
CRON_SECRET=
